  InputLines:
    - '// @input AssignableType driver {"hint":"ControllerHandDriver of the drawing hand (left). Its trigger drives the ink."}'
    - "// @input SceneObject brushTip {\"hint\":\"Where the ink comes out (e.g. the left hand's index-3 fingertip).\"}"
    - '// @input SceneObject camera {"hint":"The Spectacles Camera. Stroke ribbons face it while being drawn."}'
    - '// @input Asset.Material strokeMaterial {"hint":"Material cloned for each stroke (use an Unlit material). baseColor is set to Color."}'
    - '// @input vec4 color = {1,0.2,0.2,1} {"hint":"Stroke color.", "widget":"color"}'
    - '// @ui {"widget":"group_start", "label":"Brush"}'
    - '// @input float minThicknessCm = 0.3 {"hint":"Line thickness (cm) at a light trigger press."}'
    - '// @input float maxThicknessCm = 2 {"hint":"Line thickness (cm) at full trigger press."}'
    - '// @input float triggerThreshold = 0.1 {"hint":"Trigger value at which ink starts flowing."}'
    - '// @input float minPointDistanceCm = 0.4 {"hint":"Minimum hand travel (cm) between stroke samples."}'
    - '// @input float chunkSizePoints = 60 {"hint":"Max points per mesh CHUNK before a new one starts (seamlessly, no visible gap). Keep this LOW (e.g. 40-80) - rebuilding the stroke mesh gets more expensive the more points it has, so an unbounded single mesh will eventually stall a frame and freeze the lens. Long strokes become many small cheap chunks instead of one ever-growing expensive one."}'
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"group_start", "label":"Brush Tip Visual"}'
    - '// @input bool scaleBrushTip = true {"hint":"Scale the brushTip sphere live to match the current line thickness, based on trigger press."}'
    - "// @input float brushTipScaleMultiplier = 1 {\"hint\":\"Correction multiplier if the brushTip sphere's own mesh isn't exactly 1cm diameter at scale 1. Leave at 1 and adjust only if the sphere looks too big/small compared to the drawn line.\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"group_start", "label":"Auto delete"}'
    - "// @input bool autoDelete = true {\"hint\":\"Delete each stroke automatically after it's finished.\"}"
    - "// @input float autoDeleteSeconds = 5 {\"hint\":\"Seconds after finishing a stroke before it's deleted.\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @input AssignableType_1 interactorToSuppress {"hint":"Optional: the LEFT ControllerInteractor — suppressed while draw mode is on."}'
    - '// @input bool startEnabled {"hint":"Start with draw mode on?"}'
